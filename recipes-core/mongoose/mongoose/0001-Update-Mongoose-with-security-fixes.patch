+static size_t mg_atcmd_rx(void *buf, size_t len, struct mg_tcpip_if *ifp) {
+  struct mg_tcpip_driver_atcmd_data *dd = (struct mg_tcpip_driver_atcmd_data *) ifp->driver_data;
+  struct mg_queue *q = &ifp->recv_queue;
